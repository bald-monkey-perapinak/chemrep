# ── Anthropic (LLM) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages

# ── ElevenLabs (TTS / клонирование голоса) ────────────────────────────────
ELEVENLABS_API_KEY=...

# ── Доска (WebSocket whiteboard) ─────────────────────────────────────────
BOARD_WS_URL=ws://localhost:3001
BOARD_STUB_MODE=false

# ── База данных ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://chemrep:CHANGE_ME_STRONG_PASSWORD@localhost:5432/chemrep
POSTGRES_DB=chemrep
POSTGRES_USER=chemrep
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── S3 / MinIO ───────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=chemrep-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Embeddings (pgvector RAG) ────────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# ── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-here

# ── App ──────────────────────────────────────────────────────────────────
APP_VERSION=0.4.0

# ── Email (для отправки ДЗ) ─────────────────────────────────────────────
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=...
SMTP_PASS=...

# ── ASR / VAD ────────────────────────────────────────────────────────────
ASR_MODEL_SIZE=small
ASR_LANGUAGE=ru
VAD_AGGRESSIVENESS=1

# ── Bot stub modes (для разработки без внешних сервисов) ──────────────────
# VCS_STUB_MODE=true
# TTS_STUB_MODE=true
# ASR_STUB_MODE=true
# LLM_STUB_MODE=true
# HW_STUB_MODE=true

# ── Monitoring (prometheus/grafana) ──────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Bot timing ───────────────────────────────────────────────────────────
# SCHEDULER_POLL_INTERVAL=30
# BOT_LAUNCH_OFFSET_SEC=60
# BOT_MISSED_TIMEOUT_SEC=600
# BOT_MAX_CONCURRENT=5
# VCS_CONNECT_TIMEOUT=60
# LOG_LEVEL=INFO
